{
  "extraKnownMarketplaces": {
    "apodictic": {
      "source": {
        "source": "directory",
        "path": "tools/apodictic"
      }
    }
  },
  "enabledPlugins": {
    "apodictic@apodictic": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
